<%- include("header", {}) %>

<div style="padding:20px; max-width:800px; margin:auto;">

<h1>Usuarios Registrados</h1>
<p>Lista de usuarios en el sistema:</p>

<table border="1" cellpadding="10" cellspacing="0" style="width:100%; margin-top:15px;">
    <tr style="background:#0078ff; color:white;">
        <th>Usuario</th>
        <th>Rol</th>
    </tr>

    <% usuarios.forEach(u => { %>
        <tr>
            <td><%= u.username %></td>
            <td><%= (u.username === "admin") ? "admin" : "usuario" %></td>
        </tr>
    <% }) %>
</table>

<br>

<a href="/admin" 
   style="background:#0078ff; padding:8px 12px; color:white; text-decoration:none; border-radius:6px;">
    Volver a inicio
</a>

</div>

<%- include("footer", {}) %>
