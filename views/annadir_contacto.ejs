<%- include("header", {}) %>
    <h1>Página para añadir el contacto</h1>
    <form action="/contactos" method="post">
        <ul>
            <li>
                <label for="user_name">Nombre:</label>
                <input type="text" id="name" name="user_name" />
            </li>
            <li>
                <label for="user_age">Edad:</label>
                <input type="number" id="age" name="user_age" />
            </li>
            <li>
                <label for="user_phone">Teléfono:</label>
                <input type="number" id="phone" name="user_phone" />
            </li>
            <li>
                <label for="user_email">Correo electrónico:</label>
                <input type="email" id="email" name="user_email" />
            </li>
            <li>
                <label for="user_birthday">Cumpleaños:</label>
                <input type="date" id="birthday" name="user_birthday"/>
            </li>
            <input type="submit">
        </ul>
    </form>
<%- include("footer", {}) %>