<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Error</title>
    <link rel='stylesheet' href='/stylesheets/style.css'>
  </head>
  <body>
    <div class="container">
      <h1>Error <%= typeof error.status !== 'undefined' ? error.status : '' %></h1>
      <h2><%= message %></h2>
      <% if (error && error.stack) { %>
        <pre><%= error.stack %></pre>
      <% } %>
    </div>
  </body>
</html>